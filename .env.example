# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────

# Discord bot token from https://discord.com/developers/applications
BOT_TOKEN=your_discord_bot_token_here

# Your Discord server (guild) ID — right-click server → Copy Server ID
# Leave as 0 to sync commands globally (takes ~1 hour to propagate)
GUILD_ID=0

# Codeforces API credentials (optional — public endpoints work without these)
# Get from https://codeforces.com/settings/api
CF_API_KEY=
CF_API_SECRET=

# How long to cache the CF problemset (seconds). Default: 6 hours
PROBLEM_CACHE_TTL=21600

# How often the bot polls CF to check duel submissions (seconds). Default: 60
DUEL_POLL_INTERVAL=60

# How long a challenged user has to accept a duel (seconds). Default: 60
DUEL_ACCEPT_TIMEOUT=60

# Path to the SQLite database file
DB_PATH=data/bot.db
